"\n        window.show = true;\n\n        function start() {\n            window.counter = 50;\n            window.promise = setInterval(function () {\n                window.counter--;\n                toggleButton();\n                if (window.counter <= 0) {\n                    clearInterval(window.promise);\n                }\n            }, 50);\n        }\n\n        function toggleButton() {\n            if (window.show) {\n                var b = document.createElement(\"BUTTON\");\n                b.innerHTML = 'Click me too';\n                b.setAttribute('id', 'button');\n\n                var wrapper = document.getElementById(\"wrapper\");\n                wrapper.appendChild(b);\n                b.focus()\n            } else {\n                var b = document.getElementById(\"button\");\n                b.remove();\n            }\n            window.show = !window.show;\n        }\n    ",
